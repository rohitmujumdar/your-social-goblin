# Copy to .env and fill in. The app runs WITHOUT keys too (offline demo mode),
# but you want HydraDB + one LLM key set for the real demo.

HYDRA_DB_API_KEY=

# --- LLM brain (pick one; Nebius is auto-preferred if its key is set) ---
# Nebius Token Factory = your free $50 credits, OpenAI-compatible. Recommended.
NEBIUS_API_KEY=
# Anthropic is the alternative; used only if NEBIUS_API_KEY is blank.
ANTHROPIC_API_KEY=

# Optional overrides (defaults are fine for the hackathon)
# LLM_PROVIDER=nebius        # force a provider: nebius | anthropic | none
# NEBIUS_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
# CLAUDE_MODEL=claude-haiku-4-5-20251001
GOBLIN_TENANT_ID=the-goblin
GOBLIN_USER_ID=rohit
